# ============================================================
# UpDigitalSync — Weekly Strategy Dashboard
# Copy this file to .env and fill in real values for local runs.
# In production, the same names go into GitHub Actions Secrets.
# Do NOT commit .env — it is gitignored.
# ============================================================

# --- Apify (TikTok scraping) ---
# Token from https://console.apify.com/account/integrations
APIFY_TOKEN=

# --- Google Analytics 4 (triptiplist.com traffic) ---
# Numeric Property ID from GA4 Admin → Property Settings (9-digit number)
GA4_PROPERTY_ID=
# Service account JSON — pick ONE:
#  (a) place the JSON file as ./service-account.json next to agent.py (gitignored)
#  (b) paste the full JSON file contents here as a single-line string (CI mode)
# Service account email must be added to the GA4 property with Viewer role.
GOOGLE_SA_JSON=

# --- TwitterAPI.io (X trend scan) ---
# API key from https://twitterapi.io/dashboard
TWITTER_API_KEY=

# --- DeepSeek (synthesis / analysis) ---
# Key from https://platform.deepseek.com/api_keys
# Uses OpenAI-compatible API at https://api.deepseek.com — model: deepseek-chat
DEEPSEEK_API_KEY=
